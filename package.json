{
  "name": "pocket-lab-lite",
  "version": "1.0.0",
  "description": "Lightweight Pocket Lab for low-power Android/Termux and edge devices",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit --allowJs --checkJs false || true",
    "format:check": "prettier --check .",
    "validate:pwa": "npm run lint && npm run typecheck && npm run test && npm run build",
    "dev:mock": "VITE_POCKETLAB_MOCKS=1 vite --host 127.0.0.1",
    "test:e2e:mock": "VITE_POCKETLAB_MOCKS=1 playwright test",
    "test:visual": "playwright test tests/e2e/visual-regression.spec.ts",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "test:network": "playwright test tests/e2e/network-contracts.spec.ts",
    "test:golden": "playwright test tests/e2e/golden-path.spec.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lighthouse": "lhci autorun"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@react-spring/web": "^10.1.2",
    "@use-gesture/react": "^10.3.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@asyncapi/cli": "^6.0.2",
    "@asyncapi/html-template": "^3.5.6",
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.0.0",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.46.0",
    "@redocly/cli": "^2.31.6",
    "@storybook/addon-a11y": "^8.2.0",
    "@storybook/addon-essentials": "^8.2.0",
    "@storybook/addon-interactions": "^8.2.0",
    "@storybook/react": "^8.2.0",
    "@storybook/react-vite": "^8.2.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "ajv": "^8.17.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^24.0.0",
    "json-schema-to-typescript": "^15.0.0",
    "jsonschema": "^1.4.1",
    "lighthouse": "^12.0.0",
    "msw": "^2.4.0",
    "postcss": "^8.5.10",
    "prettier": "^3.3.0",
    "start-server-and-test": "^2.0.4",
    "storybook": "^8.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.0",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.0.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
